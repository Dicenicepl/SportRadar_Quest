<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Sports Calendar</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: system-ui, sans-serif;
            font-size: 15px;
            line-height: 1.6;
            background: #f5f5f5;
            color: #1a1a1a;
        }

        nav {
            background: #1a1a2e;
            color: #fff;
            padding: 0 2rem;
            display: flex;
            align-items: center;
            gap: 2rem;
            height: 52px;
        }
        nav .brand { font-weight: 600; font-size: 16px; color: #fff; text-decoration: none; }
        nav a { color: #aaa; text-decoration: none; font-size: 14px; }
        nav a:hover { color: #fff; }

        .container { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }

        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }
        h1 { font-size: 22px; font-weight: 600; }
        h2 { font-size: 17px; font-weight: 600; margin-bottom: 1rem; }
        h3 { font-size: 15px; font-weight: 600; margin: 1rem 0 .5rem; }

        /* Filters */
        .filters { display: flex; gap: .75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
        .filters input { padding: 6px 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }

        /* Table */
        table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
        th { text-align: left; padding: 10px 14px; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; color: #666; border-bottom: 1px solid #eee; }
        td { padding: 10px 14px; border-bottom: 1px solid #f0f0f0; font-size: 14px; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: #fafafa; }
        td a { color: #2563eb; text-decoration: none; }
        td a:hover { text-decoration: underline; }

        /* Buttons */
        .btn { display: inline-block; padding: 7px 14px; border-radius: 6px; font-size: 14px; font-weight: 500; cursor: pointer; border: 1px solid #ddd; background: #fff; color: #333; text-decoration: none; transition: background .15s; }
        .btn:hover { background: #f0f0f0; }
        .btn-primary { background: #2563eb; color: #fff; border-color: #2563eb; }
        .btn-primary:hover { background: #1d4ed8; }
        .btn-secondary { background: #fff; color: #555; }

        /* Badges */
        .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
        .badge-played    { background: #dcfce7; color: #166534; }
        .badge-scheduled { background: #dbeafe; color: #1e40af; }
        .badge-yellow    { background: #fef9c3; color: #854d0e; }
        .badge-red       { background: #fee2e2; color: #991b1b; }

        /* Detail page */
        .back-link { display: inline-block; margin-bottom: 1.25rem; color: #555; text-decoration: none; font-size: 14px; }
        .back-link:hover { color: #1a1a1a; }
        .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.5rem; }
        @@media (max-width: 700px) { .detail-grid { grid-template-columns: 1fr; } }
        .detail-card { background: #fff; border-radius: 8px; padding: 1.5rem; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
        dl { display: grid; grid-template-columns: 120px 1fr; gap: .4rem 1rem; font-size: 14px; }
        dt { color: #666; font-weight: 500; }
        dd { color: #1a1a1a; }
        .score { display: flex; align-items: center; justify-content: space-between; font-size: 15px; margin-bottom: 1rem; padding: .75rem; background: #f5f5f5; border-radius: 6px; }
        .score strong { font-size: 20px; font-weight: 700; }
        ul { list-style: none; font-size: 14px; }
        ul li { padding: 4px 0; border-bottom: 1px solid #f0f0f0; }

        /* Form */
        .form { background: #fff; padding: 1.75rem; border-radius: 8px; box-shadow: 0 1px 3px rgba(0,0,0,.08); max-width: 700px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
        @@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
        .form-group { display: flex; flex-direction: column; gap: 5px; }
        label { font-size: 13px; font-weight: 500; color: #444; }
        input, select { padding: 8px 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; background: #fff; }
        input:focus, select:focus { outline: 2px solid #2563eb; border-color: transparent; }
        .form-actions { display: flex; gap: .75rem; margin-top: 1.5rem; }

        /* Misc */
        .muted { color: #999; font-size: 13px; }
        .empty { color: #888; padding: 2rem 0; }
    </style>
</head>
<body>
    <nav>
        <a href="/" class="brand">Sports Calendar</a>
        <a href="/matches">Matches</a>
        <a href="/matches/add">Add match</a>
        <a href="#">Teams</a>
        <a href="#">Sports</a>
    </nav>

    @RenderBody()
</body>
</html>
